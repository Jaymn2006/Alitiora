# ALITIORA Environment Configuration Example
# Copy this file to .env and configure as needed

# Database
# Default: SQLite (backend/alitiora.db)
# ALITIORA_DATABASE_URL=sqlite:///./alitiora.db

# Uncomment for PostgreSQL
# ALITIORA_DATABASE_URL=postgresql://user:password@localhost:5432/alitiora

# LLM Integration (for future production use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Payment Providers
# STRIPE_SECRET_KEY=sk_test_...
# MPESA_API_KEY=...
# MPESA_CONSUMER_KEY=...
# MPESA_CONSUMER_SECRET=...

# Frontend URL (for CORS)
# FRONTEND_URL=http://localhost:3000

# Backend URL (for frontend API calls)
# BACKEND_URL=http://localhost:8000

# Session TTL (seconds, default: 604800 = 7 days)
# SESSION_TTL=604800
